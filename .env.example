# Application
ENV=development
ADMIN_TOKEN=change-me-in-prod-please
# Production QR login base URL (e.g. http://host/technodt)
QR_BASE_URL=

# Database
DATABASE_URL=postgresql+asyncpg://convert_track:convert_track@localhost:5433/convert_track
DATABASE_URL_TEST=postgresql+asyncpg://convert_track:convert_track@localhost:5433/convert_track_test

# 1С OData
ODATA_BASE_URL=http://example.invalid/odata/standard.odata
ODATA_ADMIN_USER=odata.admin
ODATA_PASSWORD=replace-me
ODATA_TIMEOUT_SECONDS=60

# Envelope barcode
ENVELOPE_BC_PREFIX=

# Initial admin credentials (web + Android TSD login)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=0000

# Auth cookie lifetime for web and Android TSD clients
AUTH_COOKIE_MAX_AGE_SECONDS=28800

# Android TSD printers
# Example: [{"id":"zpl-main","name":"Zebra склад","kind":"zpl","host":"192.168.1.50","port":9100,"dpi":200}]
PRINTERS_JSON=[]
